      "example": "2025-03-15T14:30:00Z"
    },
    "log": {
      "type": "string",
      "description": "Log message for the delivery event",
      "example": "example_value"
    },
    "status": {
      "type": "string",
      "description": "Status of the delivery event",
      "example": "example_value"
    }
  },
  "required": [
    "time",
    "log",
    "status"
  ]
}