      "example": "list"
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/DeliverabilityStatistics"
      },
      "description": "Array of deliverability statistics",
      "example": [
        {
          "from_timestamp": "2025-03-15T14:30:00Z",
          "to_timestamp": "2025-03-15T14:30:00Z",
          "reception_count": 1,
          "delivered_count": 1,
          "deferred_count": 1
        }
      ]
